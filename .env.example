# DIFARYX Agent Demo - Environment Variables

# ============================================================================
# Google Cloud Vertex AI Configuration
# ============================================================================
# Required for Vertex AI Gemini provider
# Get these from your Google Cloud Console: https://console.cloud.google.com

# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Cloud region for Vertex AI (default: us-central1)
GOOGLE_CLOUD_LOCATION=us-central1

# Enable Vertex AI mode for Google GenAI SDK
GOOGLE_GENAI_USE_VERTEXAI=true

# ============================================================================
# Gemma Open Model Configuration
# ============================================================================
# Required for Gemma provider (local or hosted)

# Gemma endpoint URL (e.g., Ollama local endpoint)
# Example for Ollama: http://localhost:11434/api/generate
GEMMA_ENDPOINT=http://localhost:11434/api/generate

# Gemma model name (default: gemma-2-9b-it)
GEMMA_MODEL=gemma-2-9b-it

# ============================================================================
# Deployment Notes
# ============================================================================
# 
# For Cloud Run deployment:
# 1. Set environment variables in Cloud Run service configuration
# 2. Ensure service account has Vertex AI User role (roles/aiplatform.user)
# 3. Enable Vertex AI API in your project
# 4. For Gemma, deploy Ollama or use a hosted endpoint
#
# For local development:
# 1. Copy this file to .env
# 2. Fill in your values
# 3. Install Ollama for local Gemma testing: https://ollama.ai
# 4. Run: ollama pull gemma-2-9b-it
# 5. Ollama will automatically start on http://localhost:11434
#
# Service Account Permissions (for Cloud Run):
# - roles/aiplatform.user (Vertex AI User)
# - roles/logging.logWriter (Cloud Logging)
# - roles/cloudtrace.agent (Cloud Trace, optional)
